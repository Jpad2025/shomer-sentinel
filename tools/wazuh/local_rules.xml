<!-- Local rules — Shomer Sentinel 2.0 -->

<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>
</group>

<!-- Escalado Suricata → Wazuh (dispara integración custom-shomer-block) -->
<group name="ids,suricata,shomer,">

  <rule id="100100" level="12">
    <if_sid>86601</if_sid>
    <field name="alert.severity">^1$</field>
    <description>Suricata: Alerta CRITICA - $(alert.signature)</description>
    <options>no_full_log</options>
    <group>attack,pci_dss_11.4,gdpr_IV_35.7.d,</group>
  </rule>

  <rule id="100101" level="8">
    <if_sid>86601</if_sid>
    <field name="alert.severity">^2$</field>
    <description>Suricata: Alerta ALTA - $(alert.signature)</description>
    <options>no_full_log</options>
    <group>attack,pci_dss_11.4,</group>
  </rule>

  <rule id="100102" level="6">
    <if_sid>86601</if_sid>
    <field name="alert.severity">^3$</field>
    <description>Suricata: Alerta MEDIA - $(alert.signature)</description>
    <options>no_full_log</options>
    <group>ids,pci_dss_11.4,</group>
  </rule>

</group>
