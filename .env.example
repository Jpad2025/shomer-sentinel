# SHOMER Sentinel - Credenciales para el Scanner (Rastreador)
# Copiar a .env y completar valores. No subir .env a control de versiones.
# Uso: WMI (Windows 135/445), SSH (Linux puerto 22). Si no se definen, se usan los valores por defecto indicados.

# WMI - Usuario y contraseña por defecto para equipos Windows (antes hardcodeados en scanner)
SHOMER_WMI_USER=shomer
SHOMER_WMI_PASSWORD=Hotel2026

# SSH - Usuario y contraseña por defecto para equipos Linux (cuando no hay credenciales en BD)
SHOMER_SSH_USER=root
SHOMER_SSH_PASSWORD=

# Opcional: ruta al binario wmiexec.py (Impacket)
# WMIEXEC_PATH=/opt/network_monitor/venv/bin/wmiexec.py
